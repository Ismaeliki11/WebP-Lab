NEXT_PUBLIC_BASE_PATH=/webp-lab

# Server-side workload limits. Keep them high because the OMV host has 15 GiB RAM.
MAX_INPUT_FILE_MB=1024
MAX_TOTAL_INPUT_MB=4096
MAX_BATCH_FILES=500
TRANSFORM_CONCURRENCY=4

# Optional external remove.bg key. Leave blank to force the local heavy model.
REMOVE_BG_API_KEY=

# Runtime paths inside the production container.
HEIF_ENC_PATH=/usr/bin/heif-enc
HEIF_DEC_PATH=/usr/bin/heif-dec

# More headroom for large ZIP jobs.
NODE_OPTIONS=--max-old-space-size=8192
