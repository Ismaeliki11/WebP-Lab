# Environment Configuration Template for WebP Lab

# Per-file size limit in MB (0 = unlimited)
MAX_INPUT_FILE_MB=0

# Total batch size limit in MB (0 = unlimited)
MAX_TOTAL_INPUT_MB=0

# Maximum concurrent file handling in a single request
MAX_BATCH_FILES=250

# Sharp engine thread count (defaults to CPU count)
TRANSFORM_CONCURRENCY=4

# Optional base path when serving the app behind a reverse proxy, e.g. /webp-lab
NEXT_PUBLIC_BASE_PATH=

# Optional remove.bg API key. If omitted, WebP Lab falls back to a local model.
REMOVE_BG_API_KEY=

# Optional absolute paths for HEIC input/output tooling
HEIF_ENC_PATH=
HEIF_DEC_PATH=

# Optional Node.js memory tuning for heavy self-hosted batches
NODE_OPTIONS=
